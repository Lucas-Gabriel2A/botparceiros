# ═══════════════════════════════════════════════════════════════════════════
# 🔐 NEXSTAR DISCORD BOTS - ARQUIVO DE EXEMPLO
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o .env com valores reais!
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# BOT TICKETS (Principal)
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN=seu_token_aqui
STAFF_ROLE_ID=id_do_cargo_staff
TICKETS_CATEGORY_ID=id_da_categoria
TICKETS_CHANNEL_ID=id_do_canal
LOGS_TICKETS=id_do_canal_logs
ANNOUNCEMENTS_CHANNEL_ID=id_do_canal_anuncios
MEMBERS_ROLE_ID=id_do_cargo_membros

# ═══════════════════════════════════════════════════════════════════════════
# BOT WELCOME
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKENS=seu_token_welcome_aqui
CLIENT_ID=seu_client_id
OWNER_ROLE_ID=id_cargo_owner
SEMI_OWNER_ROLE_ID=id_cargo_semi_owner
CATEGORY_ID=id_categoria
WELCOME_CHANNEL_ID=id_canal_welcome
LEAVE_CHANNEL_ID=id_canal_leave

# ═══════════════════════════════════════════════════════════════════════════
# BOT NEWS
# ═══════════════════════════════════════════════════════════════════════════
Discord_token_news=seu_token_news_aqui
Channel_news_category=id_categoria_news
Channel_news_id=id_canal_news
NASA_API_KEY=sua_api_key_nasa

# ═══════════════════════════════════════════════════════════════════════════
# BOT AUTOMOD
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN_AUTOMOD=seu_token_automod_aqui
CLIENT_ID_AUTOMOD=seu_client_id_automod

# ═══════════════════════════════════════════════════════════════════════════
# BOT VIP TICKETS
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN_VIP=seu_token_vip_aqui
VIP_STAFF_ROLE_ID=id_cargo_staff_vip
VIP_CARGO_VIP_ID=id_cargo_vip
VIP_CATEGORIA_TICKETS_ID=id_categoria_tickets_vip
VIP_CANAL_COMPRAS_ID=id_canal_compras
VIP_CANAL_LOGS_ID=id_canal_logs_vip

# ═══════════════════════════════════════════════════════════════════════════
# BOT CALLS PRIVADAS
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN_CALLS=seu_token_calls_aqui
CALLS_CARGO_VIP_ID=id_cargo_vip_calls
CALLS_CATEGORIA_ID=id_categoria_calls

# ═══════════════════════════════════════════════════════════════════════════
# BOT INDICAÇÕES
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN_INDICA=seu_token_indica_aqui
CATEGORIA_ANIME_FILME=id_categoria_indica
CANAL_INDICA=id_canal_indica
ANIME_SESSAO=id_canal_anime
FILME_SESSAO=id_canal_filme

# ═══════════════════════════════════════════════════════════════════════════
# BOT IA (NexstarIA)
# ═══════════════════════════════════════════════════════════════════════════
DISCORD_TOKEN_AGENTE_IA=seu_token_ia_aqui
CATEGORIA_ASSISTENTE=id_categoria_assistente
CANAL_ASSISTENTE=id_canal_assistente
CATEGORIA_CHAT_GERAL=id_categoria_chat
CANAL_CHAT_GERAL=id_canal_chat_geral

# API de IA (Groq/OpenAI)
OPENAI_API_KEY=sua_api_key_groq_ou_openai
LLM_BASE_URL=https://api.groq.com/openai/v1
MODELO_IA=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════════════════
# POSTGRESQL (Railway)
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@host:port/database
