{
  "name": "nexstar-discord-bots",
  "version": "1.0.0",
  "main": "bottickets.js",
  "scripts": {
    "start": "concurrently \"npm run start:welcome\" \"npm run start:calls\" \"npm run start:vip\" \"npm run start:news\" \"npm run start:automod\" \"npm run start:tickets\" \"npm run start:indica\" \"npm run start:ia\"",
    "start:dev": "concurrently \"npm run start:welcome:ts\" \"npm run start:calls:ts\" \"npm run start:vip:ts\" \"npm run start:news:ts\" \"npm run start:automod:ts\" \"npm run start:tickets:ts\" \"npm run start:indica:ts\" \"npm run start:ia:ts\"",
    "start:calls": "node dist/bots/callprivada/index.js",
    "start:calls:ts": "ts-node src/bots/callprivada/index.ts",
    "start:welcome": "node dist/bots/welcome/index.js",
    "start:welcome:ts": "ts-node src/bots/welcome/index.ts",
    "start:vip": "node dist/bots/ticketvip/index.js",
    "start:vip:ts": "ts-node src/bots/ticketvip/index.ts",
    "start:news": "node dist/bots/news/index.js",
    "start:news:ts": "ts-node src/bots/news/index.ts",
    "start:automod": "node dist/bots/automod/index.js",
    "start:automod:ts": "ts-node src/bots/automod/index.ts",
    "start:tickets": "node dist/bots/tickets/index.js",
    "start:tickets:ts": "ts-node src/bots/tickets/index.ts",
    "start:indica": "node dist/bots/indica/index.js",
    "start:indica:ts": "ts-node src/bots/indica/index.ts",
    "start:ia": "node dist/bots/nexstaria/index.js",
    "start:ia:ts": "ts-node src/bots/CoreIA/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "cleanup": "node src/utils/cleanup.js",
    "dev": "nodemon bottickets.js",
    "dev:ia": "nodemon --exec ts-node src/bots/ia/index.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "bot",
    "tickets",
    "partnerships",
    "calls",
    "nexstar"
  ],
  "author": "Nexstar",
  "license": "MIT",
  "description": "Sistema de tickets e calls privadas para Discord",
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.9",
    "@types/pg": "^8.16.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.12.2",
    "canvas": "^3.1.0",
    "concurrently": "^8.2.2",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "fs-extra": "^11.3.3",
    "google-translate-api-x": "^10.7.2",
    "google-tts-api": "^2.0.2",
    "libsodium-wrappers": "^0.8.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.17.0",
    "opusscript": "^0.0.8",
    "pg": "^8.18.0",
    "prism-media": "^1.3.5",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lucas-Gabriel2A/botparceiros.git"
  }
}
