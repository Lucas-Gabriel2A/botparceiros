{
  "name": "nexstar-discord-bots",
  "version": "1.0.0",
  "main": "bottickets.js",
  "scripts": {
    "start": "concurrently \"npm run start:welcome\" \"npm run start:calls\" \"npm run start:vip\" \"npm run start:news\" \"npm run start:automod\" ",
    "start:calls": "node botcallprivada.js",
    "start:welcome": "node botwelcom.js",
    "start:vip": "node botticketvip.js",
    "start:news": "node botnews.js",
    "start:automod": "node botautomod.js",
    "dev": "nodemon bottickets.js",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "discord",
    "bot",
    "tickets",
    "partnerships",
    "calls",
    "nexstar"
  ],
  "author": "Nexstar",
  "license": "MIT",
  "description": "Sistema de tickets e calls privadas para Discord",
  "dependencies": {
    "axios": "^1.12.2",
    "canvas": "^3.1.0",
    "concurrently": "^8.2.2",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lucas-Gabriel2A/botparceiros.git"
  }
