# Exemplo de configuração .env para AutoMod
# Copie este arquivo para .env e configure os valores

# Bot de AutoModeração (SEPARADO do bot principal)
DISCORD_TOKEN_AUTOMOD=SEU_TOKEN_AUTOMOD_AQUI
CLIENT_ID_AUTOMOD=SEU_CLIENT_ID_AUTOMOD_AQUI

# IMPORTANTE: Crie um bot SEPARADO no Discord Developer Portal
# para a automoderação com as seguintes permissões:
# - Read Messages
# - Send Messages
# - Delete Messages
# - Use Slash Commands
# - Read Message History